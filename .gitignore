# ==============================================================================
# ESP-IDF
# ==============================================================================
# Thư mục build chứa các file object, binaries, bootloader, partition table...
build/

# Các file do sdkconfig sinh ra
sdkconfig.old
# Cân nhắc: Commit sdkconfig.defaults và đưa 'sdkconfig' vào .gitignore 
# nếu bạn làm việc trong team để tránh conflict, hoặc nếu sdkconfig chứa 
# cấu hình wifi/password. Tuy nhiên, thông thường sdkconfig được commit 
# trong các project cá nhân/mẫu.
# sdkconfig 

# dependencies folder sinh ra bởi ESP-IDF Component Manager
managed_components/
dependencies.lock

# ==============================================================================
# IDE và Tools
# ==============================================================================
# VS Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/c_cpp_properties.json

# Eclipse / Espressif IDE
.cproject
.project
.settings/

# Clion / CMake
cmake-build-*/
.idea/

